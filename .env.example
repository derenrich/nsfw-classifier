# ==============================================================================
# NSFW Classifier Container Configuration
# ==============================================================================

# The port the FastAPI server will run on (both host and container sides).
PORT=8000

# The absolute path to your dataset directory on the host machine.
# The container will mount this directory to /datasets internally.
#
# When requesting image classification, you should pass host absolute paths
# starting with this prefix, and the FastAPI application will map them 
# automatically.
#
# Example: If your images are stored on the host at '/home/user/my_datasets/img.jpg',
# keep this prefix matching, and query using that exact path.
HOST_DATASET_PATH=/home/user/my_datasets

# Path to a SQLite database file used to cache classification scores for URLs.
# When set, repeat requests for the same URL + model skip image download and
# inference entirely.  Leave empty or unset to disable caching.
# Inside Docker the default volume is /app/cache, so a good value is:
# SCORE_CACHE_DB=/app/cache/scores.db
SCORE_CACHE_DB=

# Hugging Face User Access Token (Required to access gated/restricted models during build)
# To get a token, sign in to Hugging Face and visit https://huggingface.co/settings/tokens
HF_TOKEN=your_hugging_face_token_here
